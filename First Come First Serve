#include <bits/stdc++.h>
using namespace std;

int main() {
    int n;
    cout << "Enter number of processes: ";
    cin >> n;

    vector<int> at(n), bt(n), ct(n), tat(n), wt(n), id(n);

    // Input
    for(int i = 0; i < n; i++) {
        id[i] = i + 1;
        cout << "\nProcess " << id[i] << endl;
        cout << "Arrival Time: ";
        cin >> at[i];
        cout << "Burst Time: ";
        cin >> bt[i];
    }

    // Sort by Arrival Time (using index swapping)
    for(int i = 0; i < n - 1; i++) {
        for(int j = i + 1; j < n; j++) {
            if(at[i] > at[j]) {
                swap(at[i], at[j]);
                swap(bt[i], bt[j]);
                swap(id[i], id[j]);
            }
        }
    }

    int time = 0;

    cout << "\nGantt Chart:\n| ";

    // FCFS logic
    for(int i = 0; i < n; i++) {
        if(time < at[i]) {
            cout << "Idle | ";
            time = at[i];
        }

        ct[i] = time + bt[i];
        tat[i] = ct[i] - at[i];
        wt[i] = tat[i] - bt[i];

        cout << "P" << id[i] << " | ";
        time = ct[i];
    }

    // Timeline
    cout << "\n0 ";
    time = 0;
    for(int i = 0; i < n; i++) {
        if(time < at[i]) {
            cout << at[i] << " ";
            time = at[i];
        }
        cout << ct[i] << "  ";
        time = ct[i];
    }

    // Output Table
    cout << "\n\nP\tAT\tBT\tCT\tTAT\tWT\n";
    for(int i = 0; i < n; i++) {
        cout << "P" << id[i] << "\t"
             << at[i] << "\t"
             << bt[i] << "\t"
             << ct[i] << "\t"
             << tat[i] << "\t"
             << wt[i] << endl;
    }

    return 0;
}
