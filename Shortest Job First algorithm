#include <iostream>
#include <vector>
using namespace std;

struct Process {
    int pid, at, bt, ct, tat, wt;
    bool done = false;
};

int main() {
    int n;
    cout << "Enter number of processes: ";
    cin >> n;

    vector<Process> p(n);

    // Input
    for (int i = 0; i < n; i++) {
        p[i].pid = i + 1;
        cout << "Enter AT and BT for P" << p[i].pid << ": ";
        cin >> p[i].at >> p[i].bt;
    }

    int time = 0, completed = 0;

    cout << "\nGantt Chart:\n";
    cout << time;

    while (completed < n) {
        int idx = -1, minBT = 1e9;

        // Select shortest job among available processes
        for (int i = 0; i < n; i++) {
            if (!p[i].done && p[i].at <= time) {
                if (p[i].bt < minBT) {
                    minBT = p[i].bt;
                    idx = i;
                }
            }
        }

        // If no process available → CPU idle
        if (idx == -1) {
            time++;
            continue;
        }

        // Execute process
        cout << " | P" << p[idx].pid;

        time += p[idx].bt;
        p[idx].ct = time;
        p[idx].tat = p[idx].ct - p[idx].at;
        p[idx].wt = p[idx].tat - p[idx].bt;
        p[idx].done = true;

        cout << " | " << time;

        completed++;
    }

    // Output Table
    cout << "\n\nPID\tAT\tBT\tCT\tTAT\tWT\n";

    double totalTAT = 0, totalWT = 0;

    for (auto &x : p) {
        cout << "P" << x.pid << "\t"
             << x.at << "\t"
             << x.bt << "\t"
             << x.ct << "\t"
             << x.tat << "\t"
             << x.wt << "\n";

        totalTAT += x.tat;
        totalWT += x.wt;
    }

    // Average times (optional but good for exam)
    cout << "\nAverage Turnaround Time = " << totalTAT / n;
    cout << "\nAverage Waiting Time    = " << totalWT / n << "\n";

    return 0;
}

